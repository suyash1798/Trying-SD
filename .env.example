# Example env file (do NOT commit secrets). Use this as a template for Render.

NODE_ENV=production

# Wallet service public URL (set on Render for game-service)
WALLET_URL=https://trying-sd.onrender.com

# Game service settings
GAME_PORT=3000

# Mock frontend
# Use secure WebSocket (wss) when the site is served over https
GAME_URL=wss://trying-sd.onrender.com
USER_ID=user-1

# Redis (if using Render Redis)
REDIS_URL=redis://<render-redis-host>:6379
